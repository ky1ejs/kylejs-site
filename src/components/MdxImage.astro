---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string;
  alt?: string;
  className?: string;
}

const { src, alt = "", className } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/posts/images/*.{jpeg,jpg,png,webp}",
);

const filename = src.split("/").pop();
const matchingKey = Object.keys(images).find((key) => key.endsWith(`/${filename}`));
const image = matchingKey ? (await images[matchingKey]()).default : null;
---

{
  image ? (
    <Image src={image} alt={alt} class={className} loading="lazy" />
  ) : (
    <img src={src} alt={alt} class={className} loading="lazy" />
  )
}
