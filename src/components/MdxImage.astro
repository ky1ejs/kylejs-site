---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import sharp from "sharp";

interface Props {
  src: string;
  alt?: string;
  className?: string;
}

const { src, alt = "", className } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/posts/images/*.{jpeg,jpg,png,webp}",
);

const filename = src.split("/").pop();
const matchingKey = Object.keys(images).find((key) => key.endsWith(`/${filename}`));
const image = matchingKey ? (await images[matchingKey]()).default : null;

let placeholder: string | undefined;
if (matchingKey) {
  const filePath = `${process.cwd()}${matchingKey}`;
  const buffer = await sharp(filePath).resize(20).blur().webp({ quality: 20 }).toBuffer();
  placeholder = `data:image/webp;base64,${buffer.toString("base64")}`;
}
---

{
  image && placeholder ? (
    <Image
      src={image}
      alt={alt}
      class:list={[className, "img-loading"]}
      loading="lazy"
      style={`background-image:url(${placeholder});background-size:cover`}
      onload="this.classList.add('img-loaded')"
    />
  ) : (
    <img src={src} alt={alt} class={className} loading="lazy" />
  )
}
