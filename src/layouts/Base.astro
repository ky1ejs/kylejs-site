---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  ogUrl?: string;
  publishedTime?: string;
}

const {
  title = "kylejs",
  description = "Kyle Satti | Product Engineer based in Brooklyn, NY.",
  ogImage,
  ogType = "website",
  ogUrl,
  publishedTime,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://kylejs.me";
const canonicalUrl = ogUrl || `${siteUrl}${Astro.url.pathname}`;
const imageUrl = ogImage ? `${siteUrl}${ogImage}` : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Kyle Satti" />
    <meta property="og:locale" content="en_US" />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {publishedTime && <meta property="article:modified_time" content={publishedTime} />}
    {publishedTime && <meta property="article:author" content="Kyle Satti" />}

    {/* Twitter */}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@_kylejs_" />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    <ViewTransitions />

    {/* Theme detection - runs before paint to prevent flash */}
    <script is:inline>
      (function () {
        try {
          const theme = document.documentElement.getAttribute("data-theme");
          if (theme !== null && theme !== undefined) return;

          const cookieTheme = document.cookie
            .split("; ")
            .find((row) => row.startsWith("theme="))
            ?.split("=")[1];

          if (cookieTheme && cookieTheme !== "system") {
            document.documentElement.setAttribute("data-theme", cookieTheme);
            return;
          }

          const foundTheme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", foundTheme);
        } catch (e) {
          console.error(e);
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
