---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  ogUrl?: string;
  publishedTime?: string;
}

const {
  title = "kylejs",
  description = "Kyle Satti | Product Engineer based in Brooklyn, NY.",
  ogImage,
  ogType = "website",
  ogUrl,
  publishedTime,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://kylejs.me";
const canonicalUrl = ogUrl || `${siteUrl}${Astro.url.pathname}`;
const imageUrl = ogImage ? `${siteUrl}${ogImage}` : undefined;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Kyle Satti" />
    <meta property="og:locale" content="en_US" />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {publishedTime && <meta property="article:modified_time" content={publishedTime} />}
    {publishedTime && <meta property="article:author" content="Kyle Satti" />}

    {/* Twitter */}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@_kylejs_" />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    {/* Theme detection - runs before paint to prevent flash */}
    <script is:inline>
      function applyTheme() {
        try {
          const cookieTheme = document.cookie
            .split("; ")
            .find((row) => row.startsWith("theme="));
          const theme = cookieTheme ? cookieTheme.split("=")[1] : null;

          if (theme && theme !== "system") {
            document.documentElement.setAttribute("data-theme", theme);
          } else {
            const effective = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            document.documentElement.setAttribute("data-theme", effective);
          }
        } catch (e) {
          console.error(e);
        }
      }
      applyTheme();

      // Debug: check if cross-document view transitions are working
      window.addEventListener("pagereveal", (e) => {
        const vt = e.viewTransition;
        console.log("[VT] pagereveal: viewTransition =", vt);
        if (vt) {
          vt.ready.catch((err) => console.error("[VT] ready rejected:", err));
          vt.finished.catch((err) => console.error("[VT] finished rejected:", err));
        }
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
